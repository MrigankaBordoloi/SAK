{
  "name": "sak-college-site",
  "version": "1.0.0",
  "private": true,
  "description": "SAK College (P.G.) website — static HTML + Tailwind CSS",
  "scripts": {
    "build": "mkdir -p assets/css && tailwindcss -i ./src/input.css -o ./assets/css/output.css --minify",
    "watch": "tailwindcss -i ./src/input.css -o ./assets/css/output.css --watch",
    "serve": "serve . -l 3000",
    "dev": "concurrently -n tailwind,server -c blue,green \"npm:watch\" \"npm:serve\""
  },
  "devDependencies": {
    "tailwindcss": "^3.4.13",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "concurrently": "^9.0.1",
    "serve": "^14.2.6"
  }
}
